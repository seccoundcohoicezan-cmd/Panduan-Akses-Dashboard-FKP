<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panduan Akses Dashboard Peserta FKP</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

  :root {
    --blue: #2563EB;
    --blue-light: #EFF6FF;
    --blue-mid: #DBEAFE;
    --dark: #0F172A;
    --muted: #64748B;
    --border: #E2E8F0;
    --white: #FFFFFF;
    --surface: #F8FAFC;
    --green: #10B981;
    --green-light: #ECFDF5;
    --amber: #F59E0B;
    --amber-light: #FFFBEB;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
    background: var(--surface);
    color: var(--dark);
    line-height: 1.6;
  }

  /* HEADER */
  .header {
    background: var(--blue);
    color: #fff;
    padding: 40px 20px 60px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    width: 400px; height: 400px;
    background: rgba(255,255,255,0.06);
    border-radius: 50%;
    top: -150px; right: -100px;
  }
  .header::after {
    content: '';
    position: absolute;
    width: 300px; height: 300px;
    background: rgba(255,255,255,0.04);
    border-radius: 50%;
    bottom: -100px; left: -80px;
  }
  .header-logo {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 50px;
    padding: 8px 20px;
    font-size: 14px; font-weight: 600;
    margin-bottom: 24px;
    position: relative; z-index: 1;
  }
  .header h1 {
    font-size: clamp(22px, 5vw, 36px);
    font-weight: 800;
    line-height: 1.2;
    position: relative; z-index: 1;
  }
  .header p {
    margin-top: 10px;
    font-size: 15px;
    opacity: 0.85;
    position: relative; z-index: 1;
  }

  /* LOGIN BADGE */
  .login-badge {
    margin: -24px auto 32px;
    max-width: 480px;
    padding: 0 20px;
    position: relative; z-index: 10;
  }
  .login-card {
    background: var(--white);
    border-radius: 14px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.10);
    padding: 18px 24px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .login-icon {
    width: 44px; height: 44px;
    background: var(--blue-light);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .login-label { font-size: 12px; color: var(--muted); font-weight: 500; }
  .login-url {
    font-size: 15px; font-weight: 700; color: var(--blue);
    text-decoration: none;
  }
  .login-url:hover { text-decoration: underline; }
  .copy-btn {
    margin-left: auto;
    background: var(--blue);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 7px 14px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    flex-shrink: 0;
    font-family: inherit;
    transition: background 0.2s;
  }
  .copy-btn:hover { background: #1d4ed8; }

  /* CONTAINER */
  .container { max-width: 640px; margin: 0 auto; padding: 0 20px 60px; }

  /* SECTION TITLE */
  .section-title {
    font-size: 18px; font-weight: 700;
    margin-bottom: 16px;
    color: var(--dark);
  }

  /* STEPS */
  .steps { display: flex; flex-direction: column; gap: 12px; margin-bottom: 40px; }

  .step {
    background: var(--white);
    border-radius: 14px;
    border: 1px solid var(--border);
    overflow: hidden;
    cursor: pointer;
    transition: box-shadow 0.2s;
  }
  .step:hover { box-shadow: 0 2px 12px rgba(37,99,235,0.10); }

  .step-header {
    display: flex; align-items: center; gap: 14px;
    padding: 16px 18px;
    user-select: none;
  }

  .step-num {
    width: 34px; height: 34px;
    background: var(--blue);
    color: #fff;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700;
    flex-shrink: 0;
  }

  .step-title { font-size: 15px; font-weight: 700; flex: 1; }
  .step-icon { font-size: 18px; flex-shrink: 0; }

  .step-chevron {
    font-size: 18px; color: var(--muted);
    transition: transform 0.25s;
    flex-shrink: 0;
  }
  .step.open .step-chevron { transform: rotate(180deg); }

  .step-body {
    display: none;
    padding: 0 18px 18px 66px;
  }
  .step.open .step-body { display: block; }

  .step-body p { font-size: 14px; color: var(--muted); line-height: 1.7; }
  .step-body .highlight {
    display: inline-block;
    background: var(--blue-mid);
    color: var(--blue);
    font-weight: 600;
    border-radius: 5px;
    padding: 1px 6px;
    font-size: 13px;
  }

  /* SCREEN MOCK */
  .screen-mock {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px;
    margin-top: 12px;
    font-size: 13px;
  }
  .mock-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
  .mock-label { color: var(--muted); font-size: 12px; width: 80px; flex-shrink: 0; }
  .mock-val { font-weight: 600; font-size: 13px; }
  .badge-green {
    background: var(--green-light); color: var(--green);
    font-size: 11px; font-weight: 700;
    padding: 2px 8px; border-radius: 20px;
  }
  .badge-blue {
    background: var(--blue-light); color: var(--blue);
    font-size: 11px; font-weight: 700;
    padding: 2px 8px; border-radius: 20px;
  }

  /* STAT CARDS */
  .stat-row { display: flex; gap: 8px; margin-top: 12px; }
  .stat-card {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px;
    text-align: center;
  }
  .stat-card .emoji { font-size: 20px; }
  .stat-card .val { font-size: 18px; font-weight: 800; margin-top: 4px; }
  .stat-card .lbl { font-size: 11px; color: var(--muted); font-weight: 500; }

  /* DIVIDER */
  .divider { height: 1px; background: var(--border); margin: 32px 0; }

  /* PASSWORD TABLE */
  .pwd-section { margin-bottom: 40px; }

  .search-wrap { position: relative; margin-bottom: 14px; }
  .search-wrap input {
    width: 100%;
    padding: 12px 16px 12px 44px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 15px;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s;
    background: var(--white);
  }
  .search-wrap input:focus { border-color: var(--blue); }
  .search-wrap .search-icon {
    position: absolute; left: 14px; top: 50%; transform: translateY(-50%);
    font-size: 18px; color: var(--muted); pointer-events: none;
  }

  .pwd-table {
    background: var(--white);
    border-radius: 14px;
    border: 1px solid var(--border);
    overflow: hidden;
  }
  .pwd-table-head {
    display: grid; grid-template-columns: auto 1fr auto;
    padding: 10px 16px;
    background: var(--blue);
    color: #fff;
    font-size: 12px; font-weight: 700;
    gap: 12px;
  }
  .pwd-row {
    display: grid; grid-template-columns: auto 1fr auto;
    padding: 11px 16px;
    border-bottom: 1px solid var(--border);
    gap: 12px;
    align-items: center;
    transition: background 0.15s;
  }
  .pwd-row:last-child { border-bottom: none; }
  .pwd-row:hover { background: var(--blue-light); }
  .pwd-row .num { font-size: 12px; color: var(--muted); width: 22px; text-align: right; }
  .pwd-row .name { font-size: 14px; font-weight: 600; }
  .pwd-row .pass {
    font-family: 'Courier New', monospace;
    font-size: 13px; font-weight: 700;
    color: var(--blue);
    background: var(--blue-light);
    padding: 3px 8px; border-radius: 6px;
    letter-spacing: 0.5px;
    cursor: pointer;
    user-select: all;
  }
  .pwd-row .pass:hover { background: var(--blue-mid); }

  .no-result {
    padding: 30px;
    text-align: center;
    color: var(--muted);
    font-size: 14px;
  }

  /* CTA */
  .cta-box {
    background: linear-gradient(135deg, var(--blue) 0%, #1d4ed8 100%);
    border-radius: 16px;
    padding: 28px 24px;
    color: #fff;
    text-align: center;
  }
  .cta-box h3 { font-size: 20px; font-weight: 800; }
  .cta-box p { font-size: 14px; opacity: 0.85; margin: 8px 0 20px; }
  .cta-btn {
    display: inline-block;
    background: #fff;
    color: var(--blue);
    font-weight: 700;
    font-size: 15px;
    padding: 12px 28px;
    border-radius: 10px;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .cta-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(0,0,0,0.15); }

  /* TOAST */
  .toast {
    position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(80px);
    background: var(--dark);
    color: #fff;
    padding: 10px 20px;
    border-radius: 50px;
    font-size: 14px; font-weight: 600;
    transition: transform 0.3s ease;
    z-index: 999;
    pointer-events: none;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }
</style>
</head>
